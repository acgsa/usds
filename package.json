{
  "name": "usds",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/usds.cjs",
  "module": "./dist/usds.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/usds.js",
      "require": "./dist/usds.cjs"
    },
    "./styles": "./dist/usds.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && vite build",
    "postbuild": "node scripts/prepend-use-client.cjs",
    "build:next": "next build --no-lint",
    "dev": "next dev",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@fontsource/space-mono": "^5.3.0",
    "geist": "^1.7.2",
    "next": "^15.3.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9",
    "eslint-config-next": "^15.3.3",
    "typescript": "^5",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
